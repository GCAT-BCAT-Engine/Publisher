{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stegverse.org/schemas/emergency-ai-restriction.case.schema.json",
  "title": "Emergency AI Restriction Case",
  "description": "Schema for provisional public case records involving emergency AI restriction, model access suspension, sovereign directives, or comparable execution constraints.",
  "type": "object",
  "required": [
    "case_id",
    "title",
    "event_date",
    "date_observed",
    "case_type",
    "authority_claim",
    "execution_effect",
    "evidence_posture",
    "admissibility_status",
    "sources",
    "disputed_claims",
    "missing_primary_records"
  ],
  "properties": {
    "case_id": {
      "type": "string",
      "pattern": "^CASE-[0-9]{4}-[0-9]{2}-[A-Z0-9-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "event_date": {
      "type": "string",
      "format": "date"
    },
    "date_observed": {
      "type": "string",
      "format": "date"
    },
    "case_type": {
      "type": "string",
      "enum": [
        "emergency_ai_restriction",
        "model_access_suspension",
        "sovereign_execution_constraint",
        "export_control_action",
        "frontier_model_safety_intervention"
      ]
    },
    "authority_claim": {
      "type": "string",
      "minLength": 1
    },
    "execution_effect": {
      "type": "string",
      "minLength": 1
    },
    "affected_access_class": {
      "type": "string"
    },
    "evidence_posture": {
      "type": "string",
      "enum": [
        "public_sources_only",
        "public_sources_plus_public_claim_screenshot",
        "public_sources_plus_primary_directive",
        "primary_records_available",
        "restricted_records_referenced",
        "unknown"
      ]
    },
    "admissibility_status": {
      "type": "string",
      "enum": [
        "unresolved",
        "unresolved_without_primary_records_and_review_packet",
        "unresolved_without_directive_exploit_record_and_review_packet",
        "provisional_public_case",
        "admissible_public_record",
        "inadmissible_public_record",
        "requires_review"
      ]
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "title", "verification_status"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^SRC-[0-9]{3}$"
          },
          "type": {
            "type": "string",
            "enum": [
              "company_statement",
              "government_statement",
              "government_directive",
              "news_report",
              "user_provided_screenshot",
              "technical_report",
              "court_or_regulatory_record",
              "other"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string"
          },
          "local_reference": {
            "type": "string"
          },
          "verification_status": {
            "type": "string",
            "enum": [
              "public_source_not_independently_verified_here",
              "screenshot_claim_unverified_without_original_post_fetch",
              "primary_record_verified",
              "secondary_report_only",
              "unknown"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "disputed_claims": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "missing_primary_records": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "publisher_path": {
      "type": "string"
    },
    "source_manifest_path": {
      "type": "string"
    },
    "receipt_path": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
